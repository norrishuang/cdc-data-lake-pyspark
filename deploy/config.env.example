# =============================================================
# CDC Data Lake 部署配置示例
# 复制此文件为 config.env 并修改为实际环境的值
#   cp deploy/config.env.example deploy/config.env
# =============================================================

# ---------- 通用配置 ----------
# AWS Region
export AWS_REGION="us-east-1"

# 存放代码、依赖包、配置文件的 S3 Bucket（不带 s3:// 前缀）
export S3_BUCKET="<your-s3-bucket>"

# S3 上的部署根路径（代码与依赖会上传到该路径下）
export S3_DEPLOY_PREFIX="pyspark"

# Job 名称
export JOB_NAME="MSKServerless-TO-Iceberg"

# Kafka（MSK）消费配置
export TOPICS="<topic-name>"                       # 多个 topic 用逗号分隔
export STARTING_OFFSETS_OF_KAFKA_TOPIC="earliest"  # earliest / latest
export KAFKA_BOOSTRAPSERVER="<msk-bootstrap-server>"  # EMR Serverless 使用

# CDC 格式：debezium / dms
export CDC_FORMAT="debezium"

# 表配置文件（S3 路径）
export TABLECONFFILE="s3://${S3_BUCKET}/${S3_DEPLOY_PREFIX}/config/tables.json"

# 写入的 Iceberg database（S3 Tables 中为 namespace）名称
export DATABASE_NAME="emr_icebergdb"

# ---------- Catalog 配置 ----------
# 目标 catalog 类型：glue（Glue Data Catalog + S3）/ s3table（S3 Tables）
export CATALOG_TYPE="glue"

# Spark 中注册的 catalog 名称
#   CATALOG_TYPE=glue     时建议 glue_catalog
#   CATALOG_TYPE=s3table  时建议 s3tablesCatalog
export CATALOG_NAME="glue_catalog"

# Iceberg warehouse
#   CATALOG_TYPE=glue     时为 S3 路径，例如 s3://<bucket>/data/iceberg-folder/
#   CATALOG_TYPE=s3table  时为 S3 Tables bucket ARN，
#     例如 arn:aws:s3tables:us-east-1:123456789012:bucket/my-table-bucket
export WAREHOUSE="s3://${S3_BUCKET}/data/iceberg-folder/"

# ---------- EMR Serverless 专用 ----------
# EMR Serverless Application ID（需要 EMR 7.x；使用 S3 Tables 建议 7.5+）
export EMR_APPLICATION_ID="<application-id>"

# Job 执行角色 ARN
export EMR_JOB_ROLE_ARN="arn:aws:iam::<account-id>:role/<emr-job-role>"

# Spark Streaming checkpoint 路径
export CHECKPOINT_LOCATION="s3://${S3_BUCKET}/checkpoint/"

# Spark 资源配置
export SPARK_EXECUTOR_INSTANCES="10"
export SPARK_DRIVER_CORES="2"
export SPARK_DRIVER_MEMORY="4G"
export SPARK_EXECUTOR_CORES="2"
export SPARK_EXECUTOR_MEMORY="4G"

# Kafka 相关依赖 JAR 所在的 S3 目录（提前上传，见文档"准备依赖 JAR"一节）
export KAFKA_JARS_S3_PATH="s3://${S3_BUCKET}/${S3_DEPLOY_PREFIX}/jars"

# ---------- Glue 专用 ----------
# Glue Job 使用的 IAM Role（名称或 ARN）
export GLUE_JOB_ROLE="<glue-job-role>"

# Glue Connection 名称（Kafka/MSK 的连接，需提前在 Glue Console 创建）
export GLUE_CONNECT="<glue-connection-of-kafka>"

# Glue 临时目录
export GLUE_TEMP_DIR="s3://${S3_BUCKET}/temporary/"

# Glue Worker 配置
export GLUE_WORKER_TYPE="G.1X"
export GLUE_NUMBER_OF_WORKERS="3"

# S3 Tables Catalog JAR 版本（CATALOG_TYPE=s3table 时 Glue 需要）
export S3TABLES_CATALOG_JAR_VERSION="0.1.5"
